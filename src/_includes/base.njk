<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{% if title %}{{ title }} — {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/og-image.png">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,200;0,400;0,700;1,200;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css">
</head>
<body>
  {% include "nav.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}
  {% include "eye.njk" %}

  <script>
  (function(){
    var el=document.getElementById('weekly-countdown');
    if(!el)return;
    function update(){
      var now=new Date();
      var day=now.getDay();
      // Count days until Sunday (day 0). Monday=1 means 6 days left.
      // Sunday itself = 7 (new cycle starts Monday)
      var daysLeft=day===0?7:7-day;
      if(daysLeft<=2){
        el.style.color='var(--grey-500)';
        if(daysLeft===1){
          el.textContent='Last day online';
        }else{
          el.textContent=daysLeft+' days remaining';
        }
      }else{
        el.style.color='';
        el.textContent='Available for '+daysLeft+' days';
      }
    }
    update();
    setInterval(update,3600000);
  })();
  </script>

  <script data-collect-dnt="true" async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
</body>
</html>
