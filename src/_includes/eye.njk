];
var mx=0,my=0,activeEye=null,isHov=false,aTimer;
document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY});
function spawn(){
  if(activeEye)return;
  var pw=document.documentElement.clientWidth,sy=window.scrollY||window.pageYOffset,vh=window.innerHeight;
  var wrap=document.createElement('div');
  wrap.className='eye-wrap';
  wrap.style.left=(100+Math.random()*(pw-280))+'px';
  wrap.style.top=(sy+80+Math.random()*(vh-220))+'px';
  var frames=[];
  var hue=Math.floor(Math.random()*360);
  var accentColor='hsl('+hue+',62%,57%)';
  for(var i=0;i<stages.length;i++){var div=document.createElement('div');div.className='eye-frame';div.innerHTML=stages[i];wrap.appendChild(div);frames.push(div);
    if(i===1){var paths=div.querySelectorAll('path');if(paths.length>=2){paths[1].setAttribute('fill',accentColor)}}}
  eyeLayer.appendChild(wrap);
  var cs=-1,alive=true,blinkTimer,closing=false;
  function ss(s){if(s===cs)return;cs=s;for(var i=0;i<frames.length;i++){if(i===s)frames[i].classList.add('active');else frames[i].classList.remove('active')}}
  setTimeout(function(){wrap.style.opacity='1'},50);
  setTimeout(function(){if(alive&&!isHov&&!closing)ss(0)},400);
  setTimeout(function(){if(alive&&!isHov&&!closing)ss(1)},600);
  setTimeout(function(){if(alive&&!isHov&&!closing)ss(2)},800);
  setTimeout(function(){if(alive&&!isHov&&!closing)ss(3)},1100);
  function startBlink(){blinkTimer=setInterval(function(){if(!alive||isHov||closing)return;ss(2);setTimeout(function(){if(alive&&!isHov&&!closing)ss(1)},80);setTimeout(function(){if(alive&&!isHov&&!closing)ss(0)},140);setTimeout(function(){if(alive&&!isHov&&!closing)ss(1)},220);setTimeout(function(){if(alive&&!isHov&&!closing)ss(2)},300);setTimeout(function(){if(alive&&!isHov&&!closing)ss(3)},420)},2500+Math.random()*2000)}
  setTimeout(startBlink,1800);
  var dt=setTimeout(function(){if(!isHov&&alive)doClose()},6000+Math.random()*3000);
  function showPhoto(){
    var wr=wrap.getBoundingClientRect(),bw=document.documentElement.clientWidth,bh=window.innerHeight,s2=window.scrollY||window.pageYOffset,mw=560,px,py;
    if(wr.left>bw/2){px=48+Math.random()*Math.max(50,wr.left-mw-100)}else{px=wr.right+40+Math.random()*Math.max(50,bw-wr.right-mw-80)}
    py=s2+48+Math.random()*Math.max(50,bh-400);
    px=Math.max(20,Math.min(px,bw-mw-20));py=Math.max(s2+20,Math.min(py,s2+bh-400));
    photoImg.src=photos[Math.floor(Math.random()*photos.length)];
    photoReveal.style.left=px+'px';photoReveal.style.top=py+'px';
    openIris()}
  wrap.addEventListener('mouseenter',function(){
    if(!alive||closing)return;
    isHov=true;clearTimeout(dt);clearInterval(blinkTimer);
    ss(4);setTimeout(function(){if(isHov&&alive&&!closing)ss(5)},150);
    showPhoto()});
  wrap.addEventListener('mouseleave',function(){if(!alive)return;isHov=false;closeIris();doClose()});
  wrap.addEventListener('touchstart',function(e){
    if(!alive||closing)return;
    e.preventDefault();
    if(isHov)return;
    isHov=true;clearTimeout(dt);clearInterval(blinkTimer);
    ss(4);setTimeout(function(){if(alive&&!closing)ss(5)},150);
    setTimeout(function(){
      if(!alive||closing)return;
      isHov=false;
      ss(4);
      setTimeout(function(){if(alive&&!closing)ss(3)},200);
      // blink 1
      setTimeout(function(){if(alive&&!closing)ss(2)},600);
      setTimeout(function(){if(alive&&!closing)ss(1)},700);
      setTimeout(function(){if(alive&&!closing)ss(0)},780);
      setTimeout(function(){if(alive&&!closing)ss(1)},860);
      setTimeout(function(){if(alive&&!closing)ss(2)},940);
      setTimeout(function(){if(alive&&!closing)ss(3)},1060);
      // blink 2
      setTimeout(function(){if(alive&&!closing)ss(2)},1500);
      setTimeout(function(){if(alive&&!closing)ss(1)},1600);
      setTimeout(function(){if(alive&&!closing)ss(0)},1680);
      setTimeout(function(){if(alive&&!closing)ss(1)},1760);
      setTimeout(function(){if(alive&&!closing)ss(2)},1840);
      setTimeout(function(){if(alive&&!closing)ss(3)},1960);
      // close
      setTimeout(function(){if(alive)doClose()},2400);
    },5000);
    },{passive:false});
  function doClose(){
    if(closing)return;closing=true;
    clearInterval(blinkTimer);clearTimeout(dt);closeIris();
    // close sequence
    ss(4);
    setTimeout(function(){if(alive)ss(3)},200);
    setTimeout(function(){if(alive)ss(2)},300);
    setTimeout(function(){if(alive)ss(1)},400);
    setTimeout(function(){if(alive)ss(0)},500);
    setTimeout(function(){if(alive){cs=-1;for(var i=0;i<frames.length;i++)frames[i].classList.remove('active')}},600);
    setTimeout(function(){wrap.style.opacity='0'},700);
    setTimeout(function(){if(wrap.parentNode)wrap.parentNode.removeChild(wrap);alive=false;activeEye=null;isHov=false;sched()},1500)}
  activeEye={w:wrap}}
function sched(){clearTimeout(aTimer);aTimer=setTimeout(function(){spawn()},2500+Math.random()*4000)}
sched()})();
</script>
